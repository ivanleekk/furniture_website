---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
---

<!doctype html>
<html lang="en">
    <head>
        <BaseHead title={`${SITE_TITLE} - For Partners`} description="Partner with us to increase sales and reduce returns." />
    </head>
    <body>
        <Header />
        <main class="partner-main">
            <section class="partner-hero">
                <h1>Transform How You Sell Furniture</h1>
                <p class="hero-copy">
                    Empower your customers to visualize your furniture in their actual homes before they buy. Boost sales, eliminate guesswork, and drastically reduce returns.
                </p>
            </section>

            <section class="value-prop-section">
                <h2>Why Partner With Us?</h2>
                <div class="benefits-grid">
                    <div class="benefit-card">
                        <h3>Sell More Furniture</h3>
                        <p>Confidence drives conversions. When customers can see exactly how a piece fits and looks in their space, they are more likely to complete the purchase.</p>
                    </div>
                    <div class="benefit-card">
                        <h3>Fewer Returns</h3>
                        <p>No more "it looked smaller online" or "it doesn't match my rug". Accurate visualization means fewer costly returns and happier customers.</p>
                    </div>
                    <div class="benefit-card">
                        <h3>Universal API Integration</h3>
                        <p>Seamlessly integrate our 3D visualizer directly into your existing website. Your products, your branding, our technology.</p>
                    </div>
                    <div class="benefit-card">
                        <h3>Cross-Partner Ecosystem</h3>
                        <p>Customers can import their existing home scans and virtual inventory across all participating partners, making it easier than ever to shop for complementary pieces.</p>
                    </div>
                </div>
            </section>

            <section class="cta-section">
                <h2>Ready to elevate your retail experience?</h2>
                <p>Join our network of forward-thinking furniture retailers.</p>
                <div class="cta-actions">
                    <a class="btn btn-primary" href="mailto:e0940684@u.nus.edu">Contact Us to Partner</a>
                </div>
            </section>
        </main>
        <Footer />
    </body>
</html>

<style>
    body {
        background: radial-gradient(
            circle at top left,
            #fdfbf7,
            #f4eee6 40%,
            #e9dfd1 100%
        );
        background-attachment: fixed;
        font-family: "Poppins", "Inter", sans-serif;
    }

    :root {
        --ink: #2d261f;
        --ink-soft: #5a4f43;
        --terracotta: #bb6f4b;
        --navy-btn: #3a4b63;
        --line: #e5d2bd;
    }

    h1, h2, h3 {
        font-family: "Palatino Linotype", "Book Antiqua", Palatino, serif;
        color: var(--ink);
    }

    p {
        color: var(--ink-soft);
        line-height: 1.6;
    }

    .partner-main {
        width: min(900px, calc(100% - 3rem));
        margin: 0 auto;
        padding: 4rem 0;
        display: flex;
        flex-direction: column;
        gap: 5rem;
    }

    .partner-hero {
        text-align: center;
    }

    .partner-hero h1 {
        font-size: clamp(2.5rem, 5vw, 4rem);
        margin-bottom: 1rem;
        line-height: 1.2;
    }

    .hero-copy {
        font-size: 1.2rem;
        max-width: 700px;
        margin: 0 auto;
    }

    .value-prop-section h2 {
        text-align: center;
        font-size: 2.2rem;
        margin-bottom: 3rem;
    }

    .benefits-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 2rem;
    }

    .benefit-card {
        background: rgba(255, 255, 255, 0.6);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.4);
        padding: 2.5rem;
        border-radius: 20px;
        box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.05);
    }

    .benefit-card h3 {
        color: var(--terracotta);
        font-size: 1.4rem;
        margin-bottom: 1rem;
    }

    .cta-section {
        background: rgba(255, 255, 255, 0.4);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid rgba(255, 255, 255, 0.4);
        padding: 4rem 2rem;
        border-radius: 24px;
        text-align: center;
        box-shadow: 0 10px 40px rgba(187, 111, 75, 0.08);
    }

    .cta-section h2 {
        font-size: 2rem;
        margin-bottom: 1rem;
    }

    .cta-actions {
        margin-top: 2rem;
    }

    .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 999px;
        padding: 1rem 2rem;
        text-decoration: none;
        font-weight: 600;
        font-size: 1.1rem;
        transition: transform 160ms ease, box-shadow 160ms ease;
    }

    .btn-primary {
        background: var(--navy-btn);
        color: #fff;
        box-shadow: 0 8px 20px rgba(58, 75, 99, 0.32);
    }

    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 24px rgba(58, 75, 99, 0.4);
    }

    @media (max-width: 600px) {
        .partner-main {
            gap: 3rem;
            padding: 2rem 0;
        }
    }
</style>
