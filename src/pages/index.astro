---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
---

<!doctype html>
<html lang="en">
    <head>
        <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
        <script type="text/javascript">
            (function (c, l, a, r, i, t, y) {
                c[a] =
                    c[a] ||
                    function () {
                        (c[a].q = c[a].q || []).push(arguments);
                    };
                t = l.createElement(r);
                t.async = 1;
                t.src = "https://www.clarity.ms/tag/" + i;
                y = l.getElementsByTagName(r)[0];
                y.parentNode.insertBefore(t, y);
            })(window, document, "clarity", "script", "w48s9fhfp5");
        </script>
    </head>
    <body>
        <Header />
        <main class="landing-main">
            <section class="hero-section">
                <div class="hero-content">
                    <h1>Design your space, perfectly measured.</h1>
                    <p class="hero-copy">
                        Stop guessing, start visualizing. Scan your room, place
                        your existing furniture, and shop for new pieces from
                        top retailers—all in lifelike augmented reality.
                    </p>
                    <div class="hero-actions">
                        <a class="btn btn-primary" href="#waitlist"
                            >Get Early Access & Updates</a
                        >
                    </div>
                    <p class="microcopy">
                        Join the waitlist to be the first to experience
                        stress-free furnishing.
                    </p>
                </div>
                <div class="hero-visual-placeholder">
                    <video autoplay loop muted playsinline>
                        <source
                            src="CAD_Tool_Room_Decoration_Configurations.mp4"
                            type="video/mp4"
                        />
                        Your browser does not support the video tag.
                    </video>
                    <p>
                        <a href="/experience" class="secondary-link"
                            >View 3D Interactive Room Demo</a
                        >
                    </p>
                </div>
            </section>

            <section class="hook-section" aria-labelledby="hook-title">
                <h2 id="hook-title">
                    Moving or renovating is stressful. Buying furniture
                    shouldn't be.
                </h2>
                <p>
                    Whether you just got the keys to your new BTO, are moving
                    into a new rental, or simply want to refresh your living
                    room, we eliminate the tape-measure anxiety. Know exactly
                    how your home will look and feel <em>before</em> you spend a single
                    dollar.
                </p>
            </section>

            <section class="feature-block">
                <div class="feature-text">
                    <h2>No more guessing. Accurate floorplans in seconds.</h2>
                    <p>
                        Leave the measuring tape in the toolbox. Simply use your
                        phone's camera to scan your room. We instantly detect
                        walls, doors, and windows to generate a precise,
                        to-scale digital floorplan. It is the perfect blank
                        canvas for your dream home.
                    </p>
                </div>
                <div class="feature-visual">
                    <video
                        autoplay
                        loop
                        muted
                        playsinline
                        src="Floorplan_Generation_Video_Ready.mp4"
                    >
                    </video>
                </div>
            </section>

            <section class="feature-block reverse">
                <div class="feature-text">
                    <h2>Keep what you love. Plan around what you own.</h2>
                    <p>
                        Bringing your current sofa or favorite dining table to
                        your new place? Scan your existing furniture to create a
                        "Virtual Inventory" of 3D models. Drop them into your
                        new floorplan to see exactly where they fit. When you
                        move, your digital furniture moves with you.
                    </p>
                </div>
                <div class="feature-visual">
                    <img
                        src="scanning.png"
                        alt="Augmented Reality Catalog Browsing"
                    />
                </div>
            </section>

            <section class="feature-block">
                <div class="feature-text">
                    <h2>See it before you buy it.</h2>
                    <p>
                        Browse our integrated catalog of top furniture
                        retailers. Drop any product directly into your digital
                        room to check the fit, or use AR to project it live into
                        your physical space. Does it match the walls? Does it
                        fit next to your old coffee table? Now you'll know for
                        sure. Once it's perfect, buy it straight from the app.
                    </p>
                </div>
                <div class="feature-visual">
                    <img
                        src="AR_mode.png"
                        alt="Augmented Reality Catalog Browsing"
                    />
                </div>
            </section>

            <section class="how-it-works">
                <h2>From Empty Space to Dream Home in 3 Steps</h2>
                <div class="steps-grid">
                    <div class="step-card">
                        <div
                            class="step-icon step-icon-scan"
                            aria-hidden="true"
                        >
                            <svg viewBox="0 0 24 24" fill="none">
                                <path
                                    d="M4.5 7.5h2.25l1.2-1.8a1.5 1.5 0 0 1 1.248-.675h5.604c.5 0 .966.25 1.248.675l1.2 1.8H19.5A1.5 1.5 0 0 1 21 9v9a1.5 1.5 0 0 1-1.5 1.5h-15A1.5 1.5 0 0 1 3 18V9a1.5 1.5 0 0 1 1.5-1.5Z"
                                ></path>
                                <path d="M9 13.5a3 3 0 1 0 6 0a3 3 0 0 0-6 0Z"
                                ></path>
                            </svg>
                        </div>
                        <h3>Step 1: Scan Your Space.</h3>
                        <p>
                            Open the app and pan your camera. Get a 3D, measured
                            floorplan instantly.
                        </p>
                    </div>
                    <div class="step-card">
                        <div
                            class="step-icon step-icon-inventory"
                            aria-hidden="true"
                        >
                            <svg viewBox="0 0 24 24" fill="none">
                                <path d="M4.5 7.5L12 3l7.5 4.5L12 12L4.5 7.5Z"
                                ></path>
                                <path d="M4.5 7.5V16.5L12 21l7.5-4.5V7.5"
                                ></path>
                                <path d="M12 12v9"></path>
                            </svg>
                        </div>
                        <h3>Step 2: Bring Your Stuff.</h3>
                        <p>
                            Snap a photo of the furniture you're keeping. Watch
                            it turn into a 3D model you can place in your new
                            room.
                        </p>
                    </div>
                    <div class="step-card">
                        <div
                            class="step-icon step-icon-shop"
                            aria-hidden="true"
                        >
                            <svg viewBox="0 0 24 24" fill="none">
                                <path
                                    d="M5.25 7.5h13.5l-1.35 10.125a1.5 1.5 0 0 1-1.488 1.312H8.088A1.5 1.5 0 0 1 6.6 17.625L5.25 7.5Z"
                                ></path>
                                <path d="M9 7.5V6a3 3 0 1 1 6 0v1.5"></path>
                                <path d="m9.75 13.5 1.5 1.5 3-3"></path>
                            </svg>
                        </div>
                        <h3>Step 3: Shop & Complete.</h3>
                        <p>
                            Browse retailer catalogs, test new pieces in
                            Augmented Reality, and buy with total confidence.
                        </p>
                    </div>
                </div>
            </section>

            <section class="personas-section">
                <div class="persona-card">
                    <div class="persona-visual">
                        <img
                            src="unfurnished.png"
                            alt="unfurnished apartment"
                        />
                    </div>
                    <div class="persona-text">
                        <h3>For New Homeowners:</h3>
                        <p>
                            Plan your BTO, condo, or house perfectly before the
                            keys even arrive. Prevent costly contractor
                            miscommunications and share your vision clearly.
                        </p>
                    </div>
                </div>
                <div class="persona-card">
                    <div class="persona-visual">
                        <img src="furnished.png" alt="Furnished apartment" />
                    </div>
                    <div class="persona-text">
                        <h3>For Renters & Upgraders:</h3>
                        <p>
                            Effortlessly test out new styles and layouts without
                            the heavy lifting. Find pieces that perfectly match
                            the furniture you already own.
                        </p>
                    </div>
                </div>
            </section>

            <section id="waitlist" class="cta final-cta">
                <div class="cta-content">
                    <h2>Ready to design your space the smart way?</h2>
                    <p>
                        We are building the ultimate tool to make home
                        furnishing accurate, easy, and fun. Join our community
                        today to get exclusive launch updates, beta invites, and
                        early access to our virtual design tools.
                    </p>
                    <form class="newsletter-form">
                        <label for="email" class="sr-only">Email address</label>
                        <input
                            id="email"
                            type="email"
                            name="email"
                            placeholder="Enter your email address"
                            required
                        />
                        <button type="submit">Sign Up for Our Newsletter</button
                        >
                    </form>
                    <p class="microcopy">
                        No spam. Just updates on how to build your dream home.
                    </p>
                </div>
            </section>
        </main>
        <Footer />
    </body>
</html>

<style>
    body {
        background: radial-gradient(
            circle at top left,
            #fdfbf7,
            #f4eee6 40%,
            #e9dfd1 100%
        );
        background-attachment: fixed;
    }

    :root {
        --bg-cream: #fbf4ea;
        --bg-sand: #f0e2cf;
        --ink: #2d261f;
        --ink-soft: #5a4f43;
        --terracotta: #bb6f4b;
        --forest: #5f7254;
        --card: #fff9f1;
        --line: #e5d2bd;
        --navy-btn: #3a4b63; /* Muted navy blue */
    }

    body {
        font-family: "Poppins", "Inter", sans-serif;
    }

    .landing-main {
        width: min(1120px, calc(100% - 3rem));
        max-width: 1120px;
        padding: 2.5rem 0 4rem;
        display: flex;
        flex-direction: column;
        gap: clamp(2.25rem, 5vw, 4.5rem);
        margin: 0 auto;
        box-sizing: border-box;
    }

    .landing-main > section {
        width: 100%;
        max-width: 100%;
        margin-inline: auto;
        box-sizing: border-box;
    }

    /* Typography */
    h1,
    h2,
    h3 {
        font-family: "Palatino Linotype", "Book Antiqua", Palatino, serif;
        color: var(--ink);
    }

    p {
        color: var(--ink-soft);
        line-height: 1.6;
    }

    /* Buttons */
    .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 999px;
        padding: 0.8rem 1.8rem;
        text-decoration: none;
        border: 1px solid transparent;
        font-weight: 600;
        transition:
            transform 160ms ease,
            box-shadow 160ms ease;
    }

    .btn:hover {
        transform: translateY(-2px);
    }

    .btn-primary {
        background: var(--navy-btn);
        color: #fff;
        box-shadow: 0 8px 20px rgba(58, 75, 99, 0.32);
    }

    .microcopy {
        font-size: 0.85rem;
        color: var(--ink-soft);
        opacity: 0.8;
        margin-top: 0.8rem;
    }

    /* Hero Section */
    .hero-section {
        display: grid;
        width: 100%;
        max-width: 100%;
        box-sizing: border-box;
        grid-template-columns: repeat(auto-fit, minmax(min(320px, 100%), 1fr));
        gap: clamp(1rem, 2.8vw, 3rem);
        align-items: center;
        padding: clamp(1rem, 3.8vw, 4rem) clamp(0.85rem, 3.2vw, 3rem);
        border-radius: 28px;
        background:
            radial-gradient(
                circle at 80% 20%,
                rgba(187, 111, 75, 0.1),
                transparent 48%
            ),
            linear-gradient(130deg, var(--bg-cream), var(--bg-sand));
        box-shadow: 0 14px 38px rgba(73, 56, 40, 0.05);
        overflow: hidden;
    }

    .hero-content,
    .hero-visual-placeholder {
        min-width: 0;
    }

    .hero-section h1 {
        margin: 0 0 1rem;
        font-size: clamp(2.5rem, 4vw, 3.5rem);
        line-height: 1.1;
    }

    .hero-copy {
        font-size: 1.1rem;
        margin-bottom: 2rem;
    }

    .hero-visual-placeholder {
        height: 100%;
        min-height: clamp(220px, 40vw, 350px);
        display: flex;
        flex-direction: column;
        align-items: stretch;
        justify-content: center;
        text-align: center;
        gap: 1rem;
        padding-inline: clamp(0.25rem, 1.5vw, 0.75rem);
        color: var(--ink-soft);
    }

    .secondary-link {
        margin-top: 1rem;
        color: var(--terracotta);
        text-decoration: underline;
        font-weight: bold;
    }

    /* Hook Section */
    .hook-section {
        text-align: center;
        max-width: 100%;
        margin: 0 auto;
    }

    .hook-section h2 {
        font-size: 2.2rem;
        margin-bottom: 1.5rem;
    }

    .hook-section p {
        font-size: 1.2rem;
    }

    /* Feature Blocks */
    .feature-block {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
        align-items: start;
    }

    .feature-block.reverse {
        direction: rtl;
    }

    .feature-block.reverse > * {
        direction: ltr;
    }

    .feature-text h2 {
        font-size: 2rem;
        margin-bottom: 1rem;
    }

    .feature-visual {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: clamp(220px, 40vw, 350px);
        padding-inline: clamp(0.25rem, 1.5vw, 0.75rem);
    }

    .hero-visual-placeholder video,
    .feature-visual img,
    .feature-visual video {
        display: block;
        width: min(100%, 560px);
        max-width: 100%;
        height: auto;
        max-height: min(62vh, 420px);
        object-fit: cover;
        margin-inline: auto;
        border-radius: 16px;
        filter: drop-shadow(0 16px 28px rgba(45, 38, 31, 0.28));
    }

    .placeholder-graphic {
        color: var(--ink-soft);
        font-style: italic;
    }

    .placeholder-split {
        display: flex;
        width: 100%;
        height: 100%;
    }

    .split-half {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        border-right: 1px dashed var(--line);
        color: var(--ink-soft);
        font-style: italic;
    }
    .split-half:last-child {
        border-right: none;
    }

    /* How It Works */
    .how-it-works {
        text-align: center;
        background: #fdfaf6;
        padding: 4rem 2rem;
        border-radius: 24px;
        border: 1px solid var(--line);
    }

    .how-it-works h2 {
        font-size: 2.2rem;
        margin-bottom: 3rem;
    }

    .steps-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 2rem;
        align-items: stretch;
    }

    .step-card {
        background: rgba(255, 255, 255, 0.5);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        border: 1px solid rgba(255, 255, 255, 0.4);
        padding: 2rem;
        border-radius: 16px;
        box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.05);
        text-align: left;
        width: 100%;
        box-sizing: border-box;
    }

    .step-icon {
        width: 64px;
        height: 64px;
        background: linear-gradient(145deg, #f0dfca, #e8d0b4);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1.5rem;
        color: var(--forest);
        box-shadow: 0 10px 20px rgba(84, 68, 49, 0.15);
    }

    .step-icon svg {
        width: 30px;
        height: 30px;
        stroke: currentColor;
        stroke-width: 1.8;
        stroke-linecap: round;
        stroke-linejoin: round;
    }

    .step-icon-scan {
        color: #55725b;
    }

    .step-icon-inventory {
        color: #8c5f48;
    }

    .step-icon-shop {
        color: #3f5b74;
    }

    .step-card h3 {
        margin-bottom: 1rem;
        font-size: 1.3rem;
    }

    /* Personas Section */
    .personas-section {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2rem;
        align-items: stretch;
    }

    .persona-card {
        background: rgba(255, 255, 255, 0.55);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.4);
        box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.07);
        border-radius: 24px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        width: 100%;
        box-sizing: border-box;
    }

    .persona-visual {
        height: clamp(200px, 24vw, 280px);
        background: #e9decb;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        line-height: 0;
        color: var(--ink-soft);
        font-style: italic;
    }

    .persona-visual img {
        display: block;
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .persona-text {
        position: relative;
        z-index: 1;
        padding: 2rem;
    }

    .persona-text h3 {
        font-size: 1.4rem;
        margin-bottom: 1rem;
        color: var(--terracotta);
    }

    /* Final CTA */
    .final-cta {
        background: rgba(255, 255, 255, 0.3);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid rgba(255, 255, 255, 0.3);
        box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.1);
        border-radius: 28px;
        padding: 5rem 2rem;
        text-align: center;
        box-shadow: 0 10px 40px rgba(187, 111, 75, 0.1);
        width: 100%;
        box-sizing: border-box;
    }

    .cta-content {
        max-width: 600px;
        margin: 0 auto;
    }

    .final-cta h2 {
        font-size: 2.5rem;
        margin-bottom: 1.5rem;
        color: var(--ink);
    }

    .final-cta p {
        color: var(--ink-soft);
        margin-bottom: 2rem;
        font-size: 1.1rem;
    }

    .newsletter-form {
        display: flex;
        gap: 0.8rem;
        justify-content: center;
        flex-wrap: wrap;
    }

    .newsletter-form input {
        min-width: 300px;
        flex: 1;
        border: 2px solid white;
        border-radius: 999px;
        padding: 1rem 1.5rem;
        font-size: 1rem;
        background: rgba(255, 255, 255, 0.9);
        color: var(--ink);
    }

    .newsletter-form input:focus {
        outline: none;
        border-color: var(--terracotta);
    }

    .newsletter-form button {
        border: none;
        border-radius: 999px;
        padding: 1rem 2rem;
        font-weight: 700;
        font-size: 1rem;
        color: #fff;
        background: var(--navy-btn);
        cursor: pointer;
        transition:
            transform 160ms ease,
            box-shadow 160ms ease;
    }

    .newsletter-form button:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(58, 75, 99, 0.32);
    }

    /* Responsive */
    @media (max-width: 900px) {
        .hero-section {
            grid-template-columns: 1fr;
            padding: clamp(1.5rem, 5vw, 2.5rem) clamp(1rem, 4vw, 2rem);
        }

        .feature-block {
            grid-template-columns: 1fr;
            gap: 2rem;
        }

        .feature-block.reverse {
            direction: ltr;
        }

        .steps-grid {
            grid-template-columns: 1fr;
        }

        .personas-section {
            grid-template-columns: 1fr;
        }
    }

    @media (max-width: 600px) {
        .landing-main {
            width: min(1120px, calc(100% - 1.5rem));
            gap: 2rem;
        }

        .hero-visual-placeholder,
        .feature-visual {
            min-height: auto;
            padding-inline: 0;
        }

        .hero-visual-placeholder video,
        .feature-visual img,
        .feature-visual video {
            width: 100%;
            max-height: none;
        }

        .newsletter-form input {
            min-width: 100%;
        }

        .newsletter-form button {
            width: 100%;
        }
    }
</style>
